generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  email     String    @unique @db.VarChar(100)
  password  String    @db.VarChar(255)
  role      String    @default("admin") @db.VarChar(50)
  avatar    String?   @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("users")
}

model SiteSetting {
  id        Int      @id @default(1)
  logo      String?  @db.VarChar(500)
  logoWidth Int?     @default(140) @map("logo_width")
  siteName  String?  @map("site_name") @db.VarChar(200)
  favicon   String?  @db.VarChar(500)
  phone     String?  @db.VarChar(50)
  phone2    String?  @map("phone2") @db.VarChar(50)
  email     String?  @db.VarChar(200)
  address   String?  @db.Text
  footerText String? @map("footer_text") @db.Text
  socialLinks Json?  @map("social_links")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Navbar {
  id        Int      @id @default(autoincrement())
  menuName  String   @map("menu_name") @db.VarChar(100)
  menuLink  String   @map("menu_link") @db.VarChar(500)
  parentId  Int?     @map("parent_id")
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("navbar")
}

model HeroSlider {
  id          Int      @id @default(autoincrement())
  image       String   @db.VarChar(500)
  title       String?  @db.VarChar(255)
  subtitle    String?  @db.VarChar(255)
  description String?  @db.Text
  buttonText  String?  @map("button_text") @db.VarChar(255)
  buttonLink  String?  @map("button_link") @db.VarChar(500)
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("hero_slider")
}

model Page {
  id        Int       @id @default(autoincrement())
  pageName  String    @unique @map("page_name") @db.VarChar(100)
  heading   String?   @db.VarChar(255)
  content   String?   @db.Text
  image     String?   @db.VarChar(500)
  metaTitle String?   @map("meta_title") @db.VarChar(255)
  metaDesc  String?   @map("meta_description") @db.Text
  metaKeywords String? @map("meta_keywords") @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  sections  Section[]

  @@map("pages")
}

model Section {
  id        Int      @id @default(autoincrement())
  pageId    Int      @map("page_id")
  type      String   @db.VarChar(50)
  title     String?  @db.VarChar(255)
  subtitle  String?  @db.VarChar(255)
  content   Json?
  image     String?  @db.VarChar(500)
  position  Int      @default(0)
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("sections")
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  image       String?  @db.VarChar(500)
  serviceType String   @default("ambulance") @map("service_type") @db.VarChar(50)
  features    Json?
  status      String   @default("active") @db.VarChar(50)
  order       Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("services")
}

model Testimonial {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(150)
  position        String?  @default("") @db.VarChar(255)
  content         String   @db.Text
  rating          Int      @default(5)
  verificationUrl String?  @map("verification_url") @db.VarChar(500)
  isApproved      Boolean  @default(true) @map("is_approved")
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("testimonials")
}

model BlogPost {
  id             Int      @id @default(autoincrement())
  title          String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  content        String?  @db.LongText
  featuredImage  String?  @map("featured_image") @db.VarChar(500)
  category       String?  @default("") @db.VarChar(100)
  tags           String?  @default("") @db.VarChar(500)
  metaTitle      String?  @default("") @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description") @db.Text
  status         String   @default("draft") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("blog_posts")
}

model ServiceArea {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  description    String?  @db.Text
  contentHtml    String?  @map("content_html") @db.LongText
  faqs           Json?
  metaTitle      String?  @default("") @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description") @db.Text
  metaKeywords   String?  @map("meta_keywords") @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("service_areas")
}

model ContactLead {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(150)
  email        String   @db.VarChar(150)
  phone        String   @db.VarChar(50)
  address      String?  @default("") @db.VarChar(500)
  requirements String?  @default("") @db.VarChar(255)
  message      String?  @db.Text
  status       String   @default("new") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("contact_leads")
}

model Media {
  id         Int      @id @default(autoincrement())
  fileName   String   @map("file_name") @db.VarChar(255)
  fileUrl    String   @map("file_url") @db.VarChar(500)
  fileType   String?  @map("file_type") @db.VarChar(50)
  fileSize   Int?     @map("file_size")
  uploadedBy Int?     @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("media")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  userName  String?  @map("user_name") @db.VarChar(100)
  action    String   @db.VarChar(100)
  entity    String?  @db.VarChar(100)
  entityId  Int?     @map("entity_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}
